      "autoResize": true
    },

    {
      "type": "rectangle",
      "id": "config_struct",
      "x": 30,
      "y": 1040,
      "width": 830,
      "height": 180,
      "roundness": {"type": 3},
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeColor": "#dee2e6"
    },

    {
      "type": "text",
      "id": "t_config_detail",
      "x": 40,
      "y": 1048,
      "width": 810,
      "height": 164,
      "text": "export interface DiceBearStyleConfig {\n  id: string           // 风格 ID, e.g. 'adventurer', 'micah', 'lorelei'\n  name: string         // 显示名称\n  gender: Gender[]     // 适用性别 [M, F] 或 [M] 仅男 等\n  params: ParamDef[]   // 可调参数列表\n}\n\nexport interface ParamDef {\n  key: string          // 参数名, e.g. 'hairColor', 'clothing'\n  label: string        // 中文标签\n  type: 'select' | 'color'\n  options: ParamOption[]  // 可选值\n  default: string[]       // 默认值\n}\n\n// 然后定义 DICEBEAR_STYLES: DiceBearStyleConfig[]\n// 覆盖 8-12 种主流风格，每种带不同参数集",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "export interface DiceBearStyleConfig {\n  id: string           // 风格 ID, e.g. 'adventurer', 'micah', 'lorelei'\n  name: string         // 显示名称\n  gender: Gender[]     // 适用性别 [M, F] 或 [M] 仅男 等\n  params: ParamDef[]   // 可调参数列表\n}\n\nexport interface ParamDef {\n  key: string          // 参数名, e.g. 'hairColor', 'clothing'\n  label: string        // 中文标签\n  type: 'select' | 'color'\n  options: ParamOption[]  // 可选值\n  default: string[]       // 默认值\n}\n\n// 然后定义 DICEBEAR_STYLES: DiceBearStyleConfig[]\n// 覆盖 8-12 种主流风格，每种带不同参数集",
